{
    "document_code": "DOC_GST",
    "document_name": "GST Registration Certificate",
    "document_domain": "TAX",
    "application_scope": [
        "ALL"
    ],
    "identification": {
        "primary_keywords": [
            "GST REG-06",
            "Goods and Services Tax"
        ],
        "min_keyword_hits": 2
    },
    "issuing_authority": {
        "allowed": [
            "GST Department"
        ],
        "must_be_present": true
    },
    "mandatory_sections": [
        "legal_name",
        "gstin",
        "date_of_issue"
    ],
    "fields": {
        "gstin": {
            "regex": "\\d{2}[A-Z]{5}\\d{4}[A-Z]{1}[A-Z\\d]{1}Z[A-Z\\d]{1}",
            "match_strategy": "STRICT",
            "required": true
        },
        "legal_name": {
            "match_strategy": "STRICT",
            "required": true
        },
        "date_of_issue": {
            "date_constraint": "PAST",
            "data_type": "DATE",
            "required": true
        }
    },
    "authenticity": {
        "required": [
            "digital_signature",
            "gst_qr_code"
        ]
    },
    "risk_weight": 90,
    "verification_level": "VERY_HIGH"
}