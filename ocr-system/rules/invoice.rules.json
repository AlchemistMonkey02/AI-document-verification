{
    "document_type": "INVOICE",
    "mandatory_fields": [
        "invoice_number",
        "invoice_date",
        "total_amount",
        "gst_number"
    ],
    "field_rules": {
        "invoice_number": {
            "regex": "[a-zA-Z0-9/\\-]+",
            "exact_match": true,
            "match_strategy": "FLEXIBLE_ID"
        },
        "gst_number": {
            "regex": "\\d{2}[A-Z]{5}\\d{4}[A-Z]{1}[A-Z\\d]{1}[Z]{1}[A-Z\\d]{1}",
            "exact_match": true
        },
        "total_amount": {
            "numeric": true,
            "positive": true
        }
    },
    "cross_checks": [
        "DATE_NOT_FUTURE",
        "TOTAL_SUM_MATCH"
    ],
    "strictness": "MEDIUM"
}