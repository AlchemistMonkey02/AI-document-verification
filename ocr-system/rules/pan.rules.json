{
    "document_type": "PAN",
    "identification_keywords": [
        "Income Tax Department",
        "Permanent Account Number",
        "GOVT OF INDIA"
    ],
    "mandatory_fields": [
        "name",
        "pan_number",
        "dob"
    ],
    "field_rules": {
        "name": {
            "regex": "[A-Z\\s]+",
            "exact_match": true,
            "match_strategy": "STRICT_IDENTITY"
        },
        "pan_number": {
            "regex": "[A-Z]{5}[0-9]{4}[A-Z]",
            "exact_match": true,
            "match_strategy": "STRICT_IDENTITY"
        }
    },
    "strictness": "VERY_HIGH"
}