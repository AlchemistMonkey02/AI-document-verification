{
    "document_code": "DOC_AADHAAR",
    "document_name": "Aadhaar Card",
    "document_domain": "IDENTITY",
    "application_scope": [
        "ALL"
    ],
    "identification_keywords": [
        "Unique Identification Authority",
        "Aadhaar"
    ],
    "issuing_authorities": [
        "UIDAI"
    ],
    "mandatory_content_blocks": [
        "name",
        "dob",
        "gender",
        "aadhaar_number"
    ],
    "field_rules": {
        "name": {
            "exact_match": true
        },
        "aadhaar_number": {
            "regex": "\\d{4}\\s?\\d{4}\\s?\\d{4}",
            "exact_match": true
        },
        "dob": {
            "must_be": "PAST_DATE",
            "exact_match": true
        },
        "gender": {
            "exact_match": true
        }
    },
    "numerical_rules": {},
    "logical_rules": [
        "aadhaar_number MUST MATCH format",
        "name MUST MATCH applicant"
    ],
    "cross_document_rules": [],
    "authenticity_markers": [
        "Unique Identification Authority",
        "Government of India",
        "Satyameva Jayate",
        "Aadhaar"
    ],
    "forbidden_indicators": [
        "sample",
        "dummy",
        "void"
    ],
    "risk_weight": 50,
    "verification_level": "HIGH"
}